# MindPalace Configuration

# ── LLM ─────────────────────────────────────────────
# Option A: Local Ollama (default — no API key needed)
# Use host.docker.internal to reach Ollama running on your laptop/external machine
LLM__MODEL=ollama/llama3.1
LLM__API_KEY=
LLM__BASE_URL=http://host.docker.internal:11434

# Option B: OpenAI (uncomment and fill in API key)
# LLM__MODEL=gpt-4o-mini
# LLM__API_KEY=sk-your-key-here
# LLM__BASE_URL=

# Option C: Anthropic (uncomment and fill in API key)
# LLM__MODEL=anthropic/claude-sonnet-4-20250514
# LLM__API_KEY=sk-ant-your-key-here
# LLM__BASE_URL=

# Fallback model (optional — used if primary fails)
# LLM__FALLBACK_MODEL=ollama/mistral

LLM__TEMPERATURE=0.3
LLM__MAX_TOKENS=2048

# ── Embedding ───────────────────────────────────────
# Runs locally via sentence-transformers (no API key needed)
EMBEDDING__MODEL=all-MiniLM-L6-v2
EMBEDDING__DEVICE=cpu

# ── RAG ─────────────────────────────────────────────
RAG__TOP_K=10
RAG__CHUNK_SIZE=512
RAG__CHUNK_OVERLAP=64

# ── Database ────────────────────────────────────────
DATABASE__URL=postgresql://mindpalace:mindpalace@postgres:5432/mindpalace

# ── App ─────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8080

# ── Auth ────────────────────────────────────────────
# Secret used to sign session tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
AUTH_SECRET=change-this-to-a-random-string

# Users register via the web UI — no hardcoded credentials needed.
# Each user can create API keys for ingestion from Settings.
